# Agentic Wallet Platform - Environment Configuration

# Stellar Network Configuration
# For testnet:
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
HORIZON_API_URL=https://horizon-testnet.stellar.org

# For mainnet:
# STELLAR_NETWORK_PASSPHRASE=Public Global Stellar Network ; September 2015
# HORIZON_API_URL=https://horizon.stellar.org

# Wallet Layer
# CRITICAL: Use a strong, random password. Minimum 8 characters.
# This password encrypts all private keys at rest.
# Store in a secure secret manager in production.
WALLET_ENCRYPTION_PASSWORD=your-secure-random-password-here-min-8-chars

# CORS Configuration
# CRITICAL: Restrict to your frontend origin only. No wildcard (*) allowed.
# This prevents unauthorized cross-origin requests from malicious websites.
# Examples:
#   Development: http://localhost:3000
#   Production: https://agentic-wallet.yourcompany.com
FRONTEND_ORIGIN=http://localhost:3000

# Server Configuration
PORT=3001
NODE_ENV=development

# Optional: Logging
LOG_LEVEL=debug
